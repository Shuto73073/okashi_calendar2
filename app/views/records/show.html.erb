<div class= "mb-6">
 <h1 class="text-3xl font-bold bg-blue-200 w-fit px-2 py-1 rounded",>記録の詳細</h1>
</div>

<div class="max-w-xl mb-6">
  <div class="bg-white rounded-lg shadow-md p-4">
    
    <div class="space-y-6">
      <div class="border-b border-gray-300 pb-4">
        <p class="text-sm text-gray-700 mb-1">日付</p>
        <p class="text-lg font-medium text-gray-900"><%= @record.date %></p>
      </div>
      
      <div class="border-b border-gray-300 pb-4">
        <p class="text-sm text-gray-700 mb-1">お菓子の名前</p>
        <p class="text-lg font-medium text-gray-900"><%= @record.snack_name %></p>
      </div>
      
      <div class="border-b border-gray-300 pb-4">
        <p class="text-sm text-gray-700 mb-1">メモ</p>
        <p class="text-lg font-medium text-gray-900 whitespace-pre-wrap"><%= @record.memo %></p>
      </div>
    </div>
  </div>
</div>

<div class ="mb-2">
<%= link_to '編集に進む', edit_record_path(@record),class: "text-gray-600 hover:text-black" %>
</div>

<div class ="mb-2">
<%= link_to '一覧に戻る', records_path, class:"text-gray-600 hover:text-black" %>
</div>

<div>
<%= link_to "カレンダーに戻る", calendar_records_path, class:"text-gray-600 hover:text-black" %>
</div>